---
import StatusBadge from './StatusBadge.astro';
import type { Game } from '../lib/games';
import type { DisplayStatus } from '../lib/compat';

interface Props {
  game: Game;
  status: DisplayStatus;
}
const { game, status } = Astro.props;
---

<a href={`/game/${game.titleId}/`} class="group w-40 shrink-0 snap-start">
  <div
    class="aspect-square w-40 overflow-hidden rounded-2xl bg-white shadow-[0_10px_28px_rgba(14,30,60,0.14)] transition-transform duration-300 group-hover:-translate-y-1.5"
  >
    {
      game.cover ? (
        <img
          src={game.cover}
          alt={`${game.name} cover art`}
          width="320"
          height="320"
          loading="lazy"
          referrerpolicy="no-referrer"
          class="h-full w-full object-cover"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-slate-200 to-slate-300 p-3 text-center font-display text-xs font-semibold text-slate-500">
          {game.name}
        </div>
      )
    }
  </div>
  <p class="mt-2.5 truncate text-[13px] font-medium">{game.name}</p>
  <div class="mt-1"><StatusBadge status={status} /></div>
</a>
