---
import DashboardClient from '../components/DashboardClient.astro';
import DashboardControls from '../components/DashboardControls.astro';
import DashboardFooter from '../components/DashboardFooter.astro';
import DashboardHeader from '../components/DashboardHeader.astro';
import DashboardIntro from '../components/DashboardIntro.astro';
import PullRequestWorkspace from '../components/PullRequestWorkspace.astro';
import SummaryBar from '../components/SummaryBar.astro';
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout
  title="SharpEmu · PR Tests"
  description="Live compatibility validation results for SharpEmu pull requests."
>
  <main class="mx-auto w-full max-w-[1480px] px-8 pt-7 pb-9 max-sm:px-4 max-sm:pt-4">
    <DashboardHeader />
    <DashboardIntro />
    <SummaryBar />
    <DashboardControls />

    <p
      id="error"
      class="mb-5 rounded-xl border border-red-400/25 bg-red-400/[0.08] px-4 py-3 text-sm text-red-200"
      role="alert"
      hidden
    >
      The test runner did not respond. Retrying automatically.
    </p>

    <PullRequestWorkspace />
    <DashboardFooter />
  </main>

  <DashboardClient />
</DashboardLayout>
