---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ReportCard from '../components/ReportCard.astro';
import StatusBadge from '../components/StatusBadge.astro';
import { SITE } from '../config';
import { games, gameByAnyTitleId } from '../lib/games';
import { computeStats, STATUS_META, STATUSES } from '../lib/compat';

const compat = await getCollection('compat');
const stats = computeStats(compat.map((e) => e.data.status));

const latest = compat
  .map((entry) => ({ entry, game: gameByAnyTitleId.get(entry.data.titleId)! }))
  .filter((r) => r.game)
  .sort((a, b) => b.entry.data.testedDate.getTime() - a.entry.data.testedDate.getTime())
  .slice(0, 6);

const reachGameplay = stats.counts.ingame + stats.counts.playable;
const barSegments = STATUSES.filter((s) => stats.counts[s] > 0);
---

<Base title={`${SITE.name} — experimental PS5 emulator`}>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-40 left-1/4 h-[34rem] w-[54rem] -translate-x-1/2 rounded-full opacity-50 blur-3xl"
      style="background: radial-gradient(closest-side, #7db4ff 0%, transparent 70%);"
    >
    </div>
    <div class="mx-auto max-w-6xl px-5 pt-20 pb-4 md:pt-28">
      <p class="rise rise-1 font-mono text-[11px] font-medium tracking-[0.22em] text-muted uppercase">
        Open source · Written in C# · GPL-2.0
      </p>
      <h1
        class="rise rise-2 mt-5 max-w-2xl font-display text-5xl font-extrabold tracking-tight md:text-6xl"
      >
        The open <em class="text-psblue not-italic">PS5 emulator</em> project.
      </h1>
      <p class="rise rise-3 mt-6 max-w-xl text-lg leading-relaxed text-muted">
        SharpEmu is an experimental PlayStation 5 emulator written from scratch in C# — built in
        the open, for research and education, on Windows, Linux and macOS.
      </p>
      <div class="rise rise-4 mt-8 flex flex-wrap items-center gap-4">
        <a
          href={SITE.repoUrl}
          class="rounded-full bg-psblue px-7 py-3 text-sm font-semibold text-white shadow-[0_8px_24px_rgba(0,112,209,0.35)] transition-opacity hover:opacity-90"
          >View on GitHub</a
        >
        <a
          href="/downloads"
          class="rounded-full border border-ink/15 bg-white/60 px-7 py-3 text-sm font-semibold transition-colors hover:border-ink/30"
          >Download</a
        >
        <span class="rounded-full bg-amber-100 px-4 py-1.5 text-xs font-semibold text-amber-800">
          Early development — most games don't run yet
        </span>
      </div>

      <!-- Find your game -->
      <form action="/compatibility" method="get" class="rise rise-4 mt-12 max-w-xl">
        <label for="home-q" class="font-mono text-[11px] font-medium tracking-[0.22em] text-muted uppercase">
          Does your game run?
        </label>
        <div class="relative mt-3">
          <input
            id="home-q"
            name="q"
            type="search"
            placeholder={`Search ${games.length.toLocaleString('en-US')} PS5 titles…`}
            class="w-full rounded-full border border-ink/10 bg-white py-3.5 pr-32 pl-6 text-sm shadow-[0_10px_30px_rgba(14,30,60,0.08)] placeholder:text-muted/70 focus:border-psblue focus:ring-2 focus:ring-psblue/20 focus:outline-none"
          />
          <button
            type="submit"
            class="absolute top-1.5 right-1.5 rounded-full bg-ink px-5 py-2 text-sm font-semibold text-white transition-opacity hover:opacity-85"
            >Search</button
          >
        </div>
      </form>
    </div>
  </section>

  <!-- Compatibility right now -->
  <section class="mx-auto mt-24 max-w-6xl px-5">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h2 class="font-display text-2xl font-bold tracking-tight">Compatibility right now</h2>
        {
          stats.tested > 0 ? (
            <p class="mt-2 text-sm text-muted">
              <span class="font-semibold text-ink">{stats.tested}</span> of {games.length.toLocaleString('en-US')} tracked titles tested · <span class="font-semibold text-ink">{reachGameplay}</span> reaching gameplay — every report names the exact build.
            </p>
          ) : (
            <p class="mt-2 text-sm text-muted">
              {games.length.toLocaleString('en-US')} PS5 titles tracked, ready for their first reports.
            </p>
          )
        }
      </div>
      <a href="/compatibility" class="text-sm font-semibold text-psblue hover:underline"
        >Browse all games →</a
      >
    </div>

    {
      stats.tested > 0 && (
        <div class="mt-7">
          <div class="flex h-3 gap-[2px] overflow-hidden rounded-full" role="img" aria-label={`Status distribution across ${stats.tested} tested games`}>
            {barSegments.map((s) => (
              <div
                style={`flex: ${stats.counts[s]}; background: ${STATUS_META[s].barColor};`}
                title={`${STATUS_META[s].label}: ${stats.counts[s]}`}
              />
            ))}
          </div>
          <div class="mt-3 flex flex-wrap gap-x-5 gap-y-1.5 text-xs text-muted">
            {barSegments.map((s) => (
              <span class="inline-flex items-center gap-1.5">
                <span class="h-2.5 w-2.5 rounded-full" style={`background: ${STATUS_META[s].barColor};`} />
                {STATUS_META[s].label} · {stats.counts[s]}
              </span>
            ))}
          </div>
        </div>
      )
    }

    {
      latest.length > 0 ? (
        <>
          <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            {latest.map(({ game, entry }) => (
              <ReportCard game={game} entry={entry} />
            ))}
          </div>
          <p class="mt-6 text-sm text-muted">
            Tested something yourself?{' '}
            <a href="/compatibility/report" class="text-psblue underline">
              Submit a report
            </a>{' '}
            — it takes five minutes.
          </p>
        </>
      ) : (
        <div class="mt-8 rounded-2xl border border-dashed border-ink/15 bg-white/50 p-10 text-center">
          <p class="font-display text-lg font-bold">No reports yet — be the first</p>
          <p class="mx-auto mt-2 max-w-md text-sm text-muted">
            Every game page is ready to hold a report with the exact build, OS and hardware used.
            Run a game you own and tell everyone how far it gets.
          </p>
          <a
            href="/compatibility/report"
            class="mt-6 inline-block rounded-full bg-psblue px-6 py-2.5 text-sm font-semibold text-white transition-opacity hover:opacity-90"
          >
            Submit the first report
          </a>
        </div>
      )
    }
  </section>

  <!-- About + status ladder -->
  <section class="mx-auto mt-24 grid max-w-6xl gap-14 px-5 md:grid-cols-2">
    <div class="prose prose-slate max-w-none">
      <h2 class="font-display tracking-tight">About the project</h2>
      <p>
        SharpEmu is developed purely for research and educational purposes — we enjoy learning
        about system architecture and reverse engineering. There are no commercial goals.
      </p>
      <p>
        The emulator loads the <code>eboot.bin</code> of real games, executes native CPU
        instructions, and partially handles kernel functionality. The current focus is accuracy
        and infrastructure rather than game-specific fixes — the first games have reached the
        video-output stage.
      </p>
      <p>
        SharpEmu focuses exclusively on the PlayStation 5. For PS4 emulation, check out the
        excellent <a href="https://shadps4.net">shadPS4</a> project.
      </p>
    </div>
    <div>
      <h2 class="font-display text-2xl font-bold tracking-tight">How games are rated</h2>
      <ul class="mt-6 space-y-4">
        {
          [...STATUSES].reverse().map((s) => (
            <li class="flex items-center gap-4">
              <span class="w-24 shrink-0">
                <StatusBadge status={s} />
              </span>
              <span class="text-sm text-muted">{STATUS_META[s].description}</span>
            </li>
          ))
        }
        <li class="flex items-center gap-4">
          <span class="w-24 shrink-0"><StatusBadge status="untested" /></span>
          <span class="text-sm text-muted">
            {STATUS_META.untested.description}{' '}
            <a href="/compatibility/report" class="text-psblue underline">Submit the first report.</a>
          </span>
        </li>
      </ul>
    </div>
  </section>
</Base>
