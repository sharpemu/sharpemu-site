---
import Base from '../layouts/Base.astro';
---

<Base title="Search — SharpEmu">
  <section class="mx-auto max-w-3xl px-5 pt-12">
    <h1 class="font-display text-4xl font-extrabold tracking-tight">Search</h1>
    <p class="mt-3 text-muted">Full-text search across game pages and compatibility reports.</p>
    <div id="search" class="mt-8"></div>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({ element: '#search', showSubResults: true });
    });
  </script>

  <style is:global>
    /* Pagefind's own tokens, wired to the site's so search follows the theme. */
    #search {
      --pagefind-ui-primary: var(--color-accent);
      --pagefind-ui-text: var(--color-ink);
      --pagefind-ui-background: var(--color-field);
      --pagefind-ui-border: var(--color-line);
      --pagefind-ui-tag: var(--color-line);
      --pagefind-ui-border-radius: 16px;
      --pagefind-ui-font: 'Inter Variable', system-ui, sans-serif;
    }
    :root.dark #search .pagefind-ui__result-link {
      color: var(--color-ink);
    }
    :root.dark #search .pagefind-ui__result-excerpt {
      color: var(--color-muted);
    }
  </style>
</Base>
