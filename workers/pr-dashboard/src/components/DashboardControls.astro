<section
  class="flex items-center justify-between gap-5 py-4 max-lg:flex-col max-lg:items-stretch"
  aria-label="Dashboard controls"
>
  <div
    id="filters"
    class="flex items-center gap-1 overflow-x-auto py-1 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
    role="group"
    aria-label="Filter pull requests"
  >
    {
      [
        ['all', 'All'],
        ['mergeable', 'Mergeable'],
        ['regression', 'Regression'],
        ['testing', 'Testing'],
        ['pending', 'Pending'],
        ['stale', 'Needs rebase'],
        ['unavailable', 'Unavailable'],
      ].map(([value, label], index) => (
        <button
          class="shrink-0 rounded-full px-3.5 py-2 text-xs font-semibold text-muted transition hover:-translate-y-px hover:bg-white/[0.06] hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 aria-pressed:bg-ink aria-pressed:text-paper"
          type="button"
          data-filter={value}
          aria-pressed={index === 0 ? 'true' : 'false'}
        >
          {label}
        </button>
      ))
    }
  </div>

  <div class="flex items-center gap-2.5">
    <label class="relative flex min-w-0 flex-1 items-center text-muted">
      <svg
        class="pointer-events-none absolute left-3.5 size-4 fill-none stroke-current stroke-2"
        viewBox="0 0 24 24"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m20 20-4-4"></path>
      </svg>
      <span class="sr-only">Search pull requests</span>
      <input
        id="search"
        class="h-10 w-52 rounded-full border border-line bg-surface pr-4 pl-10 text-xs text-ink outline-none transition placeholder:text-muted/70 focus:w-64 focus:border-accent/60 focus:bg-white/[0.07] focus:ring-2 focus:ring-accent/50 max-lg:w-full max-lg:focus:w-full"
        type="search"
        autocomplete="off"
        placeholder="Search PRs"
      />
    </label>
    <button
      id="refresh"
      class="inline-flex h-10 shrink-0 items-center gap-2 rounded-full border border-line bg-surface px-4 text-xs font-semibold text-muted transition hover:border-white/20 hover:bg-white/[0.08] hover:text-ink focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/70 disabled:cursor-wait disabled:opacity-70 max-sm:size-10 max-sm:justify-center max-sm:px-0"
      type="button"
    >
      <svg
        id="refresh-icon"
        class="size-4 fill-none stroke-current stroke-2"
        viewBox="0 0 24 24"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M20 6v5h-5"></path>
        <path d="M4 18v-5h5"></path>
        <path d="M18.5 9A7 7 0 0 0 6 7l-2 4M5.5 15A7 7 0 0 0 18 17l2-4"></path>
      </svg>
      <span class="max-sm:sr-only">Refresh</span>
    </button>
  </div>
</section>
