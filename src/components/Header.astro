---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { SITE } from '../config';
---

<header class="sticky top-0 z-40 border-b border-ink/5 bg-white/60 backdrop-blur-xl">
  <nav class="mx-auto flex h-14 max-w-6xl items-center gap-7 px-5">
    <a href="/" class="flex items-center gap-2.5 font-display text-[15px] font-bold tracking-tight">
      <Image src={logo} alt={SITE.name} width={28} height={28} class="rounded-lg" />
      <span class="hidden sm:inline">{SITE.name}</span>
    </a>
    <div class="ml-auto flex items-center gap-4 text-sm font-medium text-muted sm:gap-6">
      <a href="/compatibility" class="transition-colors hover:text-ink">Compatibility</a>
      <a href="/downloads" class="transition-colors hover:text-ink">Downloads</a>
      <a href="/news" class="hidden transition-colors hover:text-ink sm:inline">News</a>
      <a href="/faq" class="hidden transition-colors hover:text-ink sm:inline">FAQ</a>
      <a href="/search" class="hidden transition-colors hover:text-ink sm:inline">Search</a>
      <a
        href={SITE.repoUrl}
        class="rounded-full bg-psblue px-4 py-1.5 text-white transition-opacity hover:opacity-85"
        >GitHub</a
      >
    </div>
  </nav>
</header>
