---
import { SITE } from '../config';
---

<footer class="mt-28 border-t border-ink/5 py-12 text-center text-xs leading-relaxed text-muted">
  <nav class="mb-8 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm font-medium">
    <a href="/compatibility" class="transition-colors hover:text-ink">Compatibility</a>
    <a href="/downloads" class="transition-colors hover:text-ink">Downloads</a>
    <a href="/news" class="transition-colors hover:text-ink">News</a>
    <a href="/faq" class="transition-colors hover:text-ink">FAQ</a>
    <a href="/search" class="transition-colors hover:text-ink">Search</a>
    <a href="/compatibility/report" class="transition-colors hover:text-ink">Submit a report</a>
  </nav>
  <div class="mx-auto max-w-3xl space-y-2 px-5">
    <p>
      {SITE.name} is an experimental, open-source research project. It is not affiliated with,
      endorsed by, or associated with Sony Interactive Entertainment. "PlayStation" and "PS5" are
      trademarks of Sony Interactive Entertainment Inc.
    </p>
    <p>
      Game titles, cover art and trademarks belong to their respective owners. Cover images are
      served from the PlayStation Store. Takedown requests:{' '}
      <a href={`${SITE.siteRepoUrl}/issues`} class="underline transition-colors hover:text-ink"
        >open an issue</a
      >.
    </p>
  </div>
</footer>
